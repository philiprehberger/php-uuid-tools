{
    "name": "philiprehberger/php-uuid-tools",
    "description": "UUID v4 and v7 generation, validation, and ordered UUIDs for database indexing",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "uuid",
        "v4",
        "v7",
        "ordered",
        "database",
        "validation"
    ],
    "homepage": "https://github.com/philiprehberger/php-uuid-tools",
    "authors": [
        {
            "name": "Philip Rehberger"
        }
    ],
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "laravel/pint": "^1.0",
        "phpstan/phpstan": "^1.12|^2.0"
    },
    "autoload": {
        "psr-4": {
            "PhilipRehberger\\UuidTools\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhilipRehberger\\UuidTools\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "lint": "vendor/bin/pint",
        "analyse": "vendor/bin/phpstan analyse"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
